# ====================================
# Mare de Brincadeiras - Backend Config
# ====================================

# Configuração do Servidor
PORT=3000
NODE_ENV=development

# Configuração JWT
JWT_SECRET=mare-access-secret-key
JWT_REFRESH_SECRET=mare-refresh-secret-key
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Configuração do Mercado Pago
# Use o token de TEST para desenvolvimento/homologação
# Use o token de PROD para produção
# MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Se não configurar o token, o backend roda em modo mock
# (retorna URL simulada de pagamento)
